{
  "expo": {
    "name": "BenimHavam",
    "slug": "benimhavam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#191970"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#191970"
      },
      "package": "com.broski.benimhavam"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}