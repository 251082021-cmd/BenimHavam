      "package": "com.broski.benimhavam",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "47287b76-0c80-47bf-98c7-c0b825661f22"
      }
    },
    "owner": "elifnazdemiray22"
